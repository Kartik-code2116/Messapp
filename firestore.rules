rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reusable Helper: Gets current user's data once to save on billable reads
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Users: Only the owner can write their own doc; mess owners can update roles/subscriptions
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        getUserData().role == "MESS_OWNER"
      );
    }

    // Messes: Public read for guest browsing; only Mess Owners can create/edit messes
    match /messes/{messId} {
      allow read: if true; 
      allow write: if request.auth != null && getUserData().role == "MESS_OWNER";
    }

    // Menus: Anyone authenticated can read; only Mess Owners can update menus
    match /menus/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && getUserData().role == "MESS_OWNER";
    }

    // Mess settings: Authenticated read; only Mess Owners can edit settings
    match /mess_settings/{messId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && getUserData().role == "MESS_OWNER";
    }

    // Meal selections: Users can read/write their own; mess owners can read/write all
    // (Mess owners need write access for "Grant Both Meals Today" feature)
    match /meal_selections/{docId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        getUserData().role == "MESS_OWNER"
      );
      allow write: if request.auth != null && (
        request.resource.data.userId == request.auth.uid ||
        getUserData().role == "MESS_OWNER"
      );
    }

    // Subscriptions & Requests: Authenticated access
    match /subscriptions/{subId} {
      allow read, write: if request.auth != null; 
    }

    match /subscriptionRequests/{reqId} {
      allow read, write: if request.auth != null;
    }

    // Mess notifications: Authenticated users can read; only Mess Owners publish notifications
    match /mess_notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && getUserData().role == "MESS_OWNER";
    }

    // Transactions: Immutable financial ledger — create only, never update/delete
    // Mess owners create transactions when granting subscriptions (userId = student's ID)
    match /transactions/{txnId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        getUserData().role == "MESS_OWNER"
      );
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Reviews: Students manage their own; mess owners read reviews matching their assigned messId
    match /reviews/{reviewId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (getUserData().role == "MESS_OWNER" && getUserData().messId == resource.data.messId)
      );
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null 
        && resource.data.userId == request.auth.uid;
    }
  }
}
