rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reusable optimized helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMessOwner() {
      return isAuthenticated() && getUserData().role == "MESS_OWNER";
    }

    // Users: only the owner can write their own doc; mess owners can also update users (for granting subscriptions)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        request.auth.uid == userId ||
        isMessOwner()
      );
    }

    // Messes: anyone can read (guest mode); only verified mess owners can write
    match /messes/{messId} {
      allow read: if true;  // Guest mode needs public read
      allow write: if isMessOwner();
    }

    // Menus: anyone authenticated can read; only mess owners can write
    match /menus/{docId} {
      allow read: if isAuthenticated();
      allow write: if isMessOwner();
    }

    // Mess settings: authenticated read; only mess owners can write
    match /mess_settings/{messId} {
      allow read: if isAuthenticated();
      allow write: if isMessOwner();
    }

    // Meal selections: users can write their own; mess owner can read all
    match /meal_selections/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Subscriptions: authenticated access only
    match /subscriptions/{subId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Subscription requests: authenticated access only
    match /subscriptionRequests/{reqId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Mess notifications: authenticated users in the app can read/write feed items
    match /mess_notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Transactions: authenticated read; only mess owners can create; no updates/deletes allowed
    match /transactions/{txnId} {
      allow read: if isAuthenticated();
      allow create: if isMessOwner();
      allow update, delete: if false;
    }

    // Reviews: students can read/manage their own reviews; mess owners can read reviews for their own mess
    match /reviews/{reviewId} {
      allow read: if isAuthenticated()
        && (
          resource.data.userId == request.auth.uid ||
          (
            isMessOwner() &&
            getUserData().messId == resource.data.messId
          )
        );
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }
  }
}
