<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Profound.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/charcoal_border</item>
    </style>

    <style name="Profound.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Profound.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
    </style>

    <style name="ProfileSectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/text_caption</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="ProfileCard" parent="Profound.Card">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Profound.InputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="hintTextColor">@color/text_caption</item>
    </style>
</resources>
