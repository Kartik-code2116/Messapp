<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_page">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment_activity_user_dashboard"
        android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/nav_view"
            app:defaultNavHost="true"
            app:navGraph="@navigation/mobile_navigation" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/neutral_200"
            android:layout_above="@id/nav_view"/>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/nav_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@color/surface_card"
            android:elevation="0dp"
            app:itemIconTint="@color/selector_nav_user"
            app:itemTextColor="@color/selector_nav_user"
            app:itemRippleColor="@color/brand_primary_light"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu"
            app:itemActiveIndicatorStyle="@style/Widget.Material3.BottomNavigationView.ActiveIndicator" />

        <!-- We removed the standard toolbar to let fragments handle their own headers for a more immersive feel -->
    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/profile_drawer"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/surface_card"
        app:headerLayout="@layout/header_user_profile_drawer"
        app:itemIconTint="@color/brand_primary"
        app:itemTextColor="@color/text_heading"
        app:menu="@menu/menu_user_profile_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
