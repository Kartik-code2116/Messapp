<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background">

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:elevation="10dp"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Header Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/card_surface"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp"
                android:elevation="2dp">

                <TextView
                    android:id="@+id/text_revenue_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Financial Insights"
                    android:textColor="@color/text_main"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/text_revenue_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/text_revenue_title"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Track earnings and projections"
                    android:textColor="@color/text_sub"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btn_edit_price"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/accent_primary" />
            </RelativeLayout>

            <!-- Main Metrics Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_color">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="@drawable/bg_gradient_primary"
                    android:backgroundTint="#F0F4FF">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-bold"
                        android:text="THIS MONTH (EXPECTED)"
                        android:textColor="@color/accent_primary"
                        android:textSize="10sp"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/text_monthly_revenue_expected"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-black"
                        android:text="₹0.00"
                        android:textColor="@color/text_main"
                        android:textSize="32sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="Actual"
                                android:textColor="@color/text_sub"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/text_monthly_revenue_actual"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif-bold"
                                android:text="₹0.00"
                                android:textColor="#10B981"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginHorizontal="16dp"
                            android:background="@color/border_color" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:text="Total (All Time)"
                                android:textColor="@color/text_sub"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/text_total_revenue_all_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="sans-serif-bold"
                                android:text="₹0.00"
                                android:textColor="@color/text_main"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Basis Info -->
            <TextView
                android:id="@+id/text_revenue_basis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="Based on 0 active subscriptions at ₹0.00/mo"
                android:textColor="@color/text_placeholder"
                android:textSize="11sp" />

            <!-- Filters Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edit_search_transactions"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rounded_input"
                        android:drawableStart="@android:drawable/ic_menu_search"
                        android:drawablePadding="12dp"
                        android:drawableTint="@color/text_placeholder"
                        android:fontFamily="sans-serif-medium"
                        android:hint="Search student or email"
                        android:inputType="text"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_main"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/btn_filter_date"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_rounded_input"
                        android:padding="14dp"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="@color/text_sub" />
                </LinearLayout>

                <TextView
                    android:id="@+id/text_active_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_capsule_accent"
                    android:backgroundTint="@color/accent_primary"
                    android:fontFamily="sans-serif-bold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Date: Oct 2023 ✕"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </LinearLayout>

            <!-- Transactions Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="Recent Transactions"
                    android:textColor="@color/text_main"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/text_transaction_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-bold"
                    android:text="0 total"
                    android:textColor="@color/text_placeholder"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view_transactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="12dp"
                tools:listitem="@layout/item_transaction" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Hidden field for compatibility -->
    <TextView
        android:id="@+id/text_mess_monthly_price"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</FrameLayout>
