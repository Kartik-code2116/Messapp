<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:elevation="10dp"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        tools:context=".ui.user.profile.UserProfileFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- Profile Header Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="40dp"
                android:paddingBottom="32dp"
                android:background="@color/accent_primary">

                <RelativeLayout
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/profile_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/divider"
                        android:padding="4dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_person_black_24dp"
                        android:contentDescription="Profile Image"
                        app:shapeAppearanceOverlay="@style/CircleImageStyle"
                        android:outlineProvider="background"
                        android:elevation="4dp" />

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btn_edit_profile_image"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:contentDescription="Edit Profile Image"
                        app:fabCustomSize="32dp"
                        app:srcCompat="@drawable/ic_edit"
                        app:tint="@color/white"
                        app:backgroundTint="@color/ios_primary"
                        android:layout_margin="2dp" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/text_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="John Doe"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-bold"/>

                <TextView
                    android:id="@+id/text_profile_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="john.doe@example.com"
                    android:textColor="@color/white"
                    android:alpha="0.9"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_admin_icon_primary"
                    android:fontFamily="sans-serif-black"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="STUDENT ACCOUNT"
                    android:textColor="@color/white"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- Content Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="24dp">

                <!-- Subscription Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:background="@color/card_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_person_black_24dp"
                                app:tint="@color/accent_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Subscription Details"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_main"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:baselineAligned="false">
                            
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mess Name"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_sub"/>
                                <TextView
                                    android:id="@+id/text_profile_mess_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="Sunshine Mess"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_main"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1.2"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Subscription Status"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_sub"/>
                                <TextView
                                    android:id="@+id/text_lunch_expiry"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="Lunch: Active"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@android:color/holo_green_dark"/>
                                <TextView
                                    android:id="@+id/text_dinner_expiry"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    tools:text="Dinner: Active"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@android:color/holo_green_dark"/>
                                <!-- Keep legacy ID hidden for binding safety if needed -->
                                <TextView
                                    android:id="@+id/text_subscription_expiry"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:visibility="gone"/>
                            </LinearLayout>
                        </LinearLayout>
                        
                         <TextView
                             android:id="@+id/text_profile_mess_id"
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:visibility="gone"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_renew_subscription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="Renew Subscription"
                            android:textColor="@color/ios_primary"
                            app:strokeColor="@color/ios_primary"
                            app:cornerRadius="12dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Personal Info Card -->
                 <!-- Assuming binding will need text_profile_phone etc if we display here, 
                      but original layout didn't have phone textviews bound in fragment explicitly visible 
                      outside of Edit Profile possibly. We will stick to Settings for now matching previous scope. -->

                <!-- Appearance Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/card_surface">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="APPEARANCE"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_placeholder"
                            android:letterSpacing="0.1"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_edit"
                                app:tint="@color/accent_primary" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:text="Dark Mode"
                                android:textColor="@color/text_main"
                                android:textSize="16sp" />

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/switch_dark_mode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Account Settings Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/card_surface">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SETTINGS"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_placeholder"
                            android:letterSpacing="0.1"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="20dp"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:id="@+id/btn_my_reviews"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_check_circle"
                                app:tint="@color/accent_primary" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:text="Mess Reviews"
                                android:textColor="#111827"
                                android:textSize="16sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_arrow_back_black_24dp"
                                app:tint="#9CA3AF" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="#E5E7EB" />

                        <LinearLayout
                            android:id="@+id/btn_change_password"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_lock"
                                app:tint="@color/accent_primary" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:text="Change Password"
                                android:textColor="#111827"
                                android:textSize="16sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_arrow_back_black_24dp"
                                app:tint="#9CA3AF" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="#E5E7EB" />

                        <LinearLayout
                            android:id="@+id/btn_help_support"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_info_black_24dp"
                                app:tint="@color/accent_primary" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:text="Help / Support"
                                android:textColor="#111827"
                                android:textSize="16sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_arrow_back_black_24dp"
                                app:tint="#9CA3AF" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="#E5E7EB" />

                        <LinearLayout
                            android:id="@+id/btn_logout"
                            android:layout_width="match_parent"
                            android:layout_height="64dp"
                            android:background="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_lock"
                                app:tint="#EF4444" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:text="Logout"
                                android:textColor="#EF4444"
                                android:textSize="16sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_arrow_back_black_24dp"
                                app:tint="#9CA3AF" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
