<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page"
    tools:context=".ui.mess.profile.MessProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- Custom App Bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_card"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Owner Profile"
                android:textColor="@color/text_heading"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btn_logout_top"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_lock"
                android:contentDescription="Logout"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_heading" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Profile Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <RelativeLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/mess_profile_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/neutral_200"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_account_circle"
                    android:contentDescription="Mess Profile Image"
                    app:shapeAppearanceOverlay="@style/CircleImageStyle"
                    android:outlineProvider="background"
                    android:elevation="0dp" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/btn_edit_profile_image"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:contentDescription="Edit Profile Image"
                    app:fabCustomSize="36dp"
                    app:srcCompat="@drawable/ic_edit"
                    app:tint="@color/white"
                    app:backgroundTint="@color/brand_primary"
                    app:borderWidth="0dp"
                    style="@style/Widget.MaterialComponents.FloatingActionButton" />
            </RelativeLayout>

            <TextView
                android:id="@+id/text_mess_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:text="Mess Name"
                android:textStyle="bold"
                android:textColor="@color/text_heading"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/text_owner_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/inter"
                android:text="owner@example.com"
                android:textColor="@color/text_sub" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_card_surface"
                android:backgroundTint="@color/brand_primary_light"
                android:fontFamily="@font/inter"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="ADMIN ACCOUNT"
                android:textColor="@color/brand_primary"
                android:textStyle="bold"
                android:textSize="10sp"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- Metrics & Quick Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Mess Details Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Profound.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:orientation="horizontal"
                         android:gravity="center_vertical">
                         
                         <TextView
                             android:id="@+id/label_mess_details"
                             android:layout_width="0dp"
                             android:layout_weight="1"
                             android:layout_height="wrap_content"
                             android:fontFamily="@font/poppins"
                             android:text="Mess Details"
                             android:textColor="@color/text_heading"
                             android:textSize="18sp"
                             android:textStyle="bold"/>

                        <LinearLayout
                            android:id="@+id/container_mess_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rounded_card_surface"
                            android:backgroundTint="@color/neutral_100"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp">

                            <TextView
                                android:id="@+id/text_mess_profile_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:text="#MS-9921"
                                android:textColor="@color/text_sub"
                                android:textSize="12sp" />

                            <ImageView
                                android:id="@+id/btn_copy_mess_id"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_edit"
                                android:contentDescription="Copy ID"
                                app:tint="@color/brand_primary" />
                        </LinearLayout>
                     </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/neutral_200"
                        android:layout_marginVertical="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_location_on"
                                android:contentDescription="Location Icon"
                                app:tint="@color/text_sub"
                                android:layout_marginTop="2dp"/>

                            <TextView
                                android:id="@+id/text_mess_profile_location"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:fontFamily="@font/inter"
                                android:text="Location loading..."
                                android:textColor="@color/text_body"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_call"
                                android:contentDescription="Contact Icon"
                                app:tint="@color/text_sub" />

                            <TextView
                                android:id="@+id/text_mess_profile_contact"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:fontFamily="@font/inter"
                                android:text="Contact loading..."
                                android:textColor="@color/text_body"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="top"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_info"
                                android:contentDescription="Description Icon"
                                app:tint="@color/text_sub"
                                android:layout_marginTop="2dp"/>

                            <TextView
                                android:id="@+id/text_mess_profile_description"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:fontFamily="@font/inter"
                                android:textStyle="italic"
                                android:text="Description loading..."
                                android:textColor="@color/text_body"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Total Students Metric Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Profound.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:gravity="center_vertical">
                         
                        <TextView
                            android:id="@+id/label_active_students"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="Active Students"
                            android:textColor="@color/text_caption"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:letterSpacing="0.05"/>
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_rounded_card_surface"
                            android:backgroundTint="@color/semantic_success"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="LIVE"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_active_students_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="128"
                        android:textColor="@color/text_heading"
                        android:textStyle="bold"
                        android:textSize="36sp"
                        android:layout_marginTop="4dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_check_circle"
                            android:contentDescription="Trend Icon"
                            app:tint="@color/semantic_success" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="+12% this month"
                            android:textColor="@color/semantic_success"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_view_students"
                        style="@style/Profound.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="View Full List"
                        android:layout_marginTop="16dp"
                        app:strokeColor="@color/neutral_300"
                        android:textColor="@color/text_sub"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Management Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.05"
                android:text="MANAGEMENT"
                android:textStyle="bold"
                android:textColor="@color/text_caption"
                android:textSize="12sp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Profound.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Edit Profile -->
                    <LinearLayout
                        android:id="@+id/btn_nav_edit_profile"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_edit"
                            android:contentDescription="Edit Profile"
                            app:tint="@color/brand_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:text="Edit Mess Profile"
                            android:textColor="@color/text_heading"
                            android:fontFamily="@font/inter"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:contentDescription="Navigate"
                            app:tint="@color/neutral_400" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/neutral_100" />

                    <!-- Campaigns -->
                    <LinearLayout
                        android:id="@+id/btn_nav_offers"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_local_offer"
                            android:contentDescription="Campaigns"
                            app:tint="@color/brand_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:text="Campaigns &amp; Offers"
                            android:textColor="@color/text_heading"
                            android:fontFamily="@font/inter"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rounded_card_surface"
                            android:backgroundTint="@color/semantic_success"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="3 LIVE"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:textSize="10sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:contentDescription="Navigate"
                            app:tint="@color/neutral_400" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/neutral_100" />

                    <!-- Revenue Reports -->
                    <LinearLayout
                        android:id="@+id/btn_nav_revenue"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_bar_chart"
                            android:contentDescription="Revenue"
                            app:tint="@color/brand_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:text="Revenue Reports"
                            android:textColor="@color/text_heading"
                            android:fontFamily="@font/inter"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:contentDescription="Navigate"
                            app:tint="@color/neutral_400" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Appearance Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.05"
                android:text="APPEARANCE"
                android:textStyle="bold"
                android:textColor="@color/text_caption"
                android:textSize="12sp" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Profound.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Dark Mode Toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_dark_mode"
                            android:contentDescription="Dark Mode"
                            app:tint="@color/text_sub" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:text="Dark Mode"
                            android:textColor="@color/text_heading"
                            android:fontFamily="@font/inter"
                            android:textSize="16sp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_dark_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logout -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mess_logout"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Logout Account"
                android:textColor="@color/semantic_error"
                android:textStyle="bold"
                app:icon="@drawable/ic_lock"
                app:iconGravity="textStart"
                app:iconTint="@color/semantic_error" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Version 2.4.1 (Profound Build 1.0)"
                android:textColor="@color/text_caption"
                android:fontFamily="@font/inter"
                android:textSize="12sp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>