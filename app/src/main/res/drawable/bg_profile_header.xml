<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Base Warm Food Brand Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/brand_primary"
                android:endColor="@color/brand_primary_dark"
                android:type="linear" />
            <corners
                android:bottomLeftRadius="40dp"
                android:bottomRightRadius="40dp" />
        </shape>
    </item>

    <!-- Translucent Overlay for Glassmorphism & Depth -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="#26FFFFFF"
                android:centerColor="#00000000"
                android:endColor="#1A000000"
                android:type="linear" />
            <corners
                android:bottomLeftRadius="40dp"
                android:bottomRightRadius="40dp" />
        </shape>
    </item>

</layer-list>
