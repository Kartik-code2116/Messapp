<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_primary">

    <!-- Center Content -->
    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Animated Logo Container -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_rounded_white"
            android:elevation="8dp"
            android:padding="24dp">

            <ImageView
                android:id="@+id/app_logo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/splash_logo_content_description"
                android:src="@drawable/ic_restaurant"
                app:tint="@color/primary_color" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-black"
            android:shadowColor="#40000000"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="40sp"
            android:textStyle="bold" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.05"
            android:text="Your Daily Meals, Simplified"
            android:textColor="@color/text_on_primary_muted"
            android:textSize="16sp" />

        <!-- Progress Bar (Visual Only) -->
        <ProgressBar
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="200dp"
            android:layout_height="4dp"
            android:layout_marginTop="48dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/white"
            android:progress="0"
            android:progressDrawable="@drawable/bg_rounded_white" />

    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="264dp"
        android:layout_height="92dp"
        android:layout_below="@+id/linearLayout"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="69dp"
        android:layout_marginTop="160dp"
        android:layout_marginEnd="78dp"
        android:text="Connecting you to great food"
        android:textColor="@color/text_on_primary_muted"
        android:textSize="14sp" />

</RelativeLayout>
