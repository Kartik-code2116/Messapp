<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@color/success"
            android:padding="8dp"
            android:background="@drawable/bg_circle_light_green"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/text_trans_student_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Name"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/text_trans_student_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="student@email.com"
                android:textSize="12sp"
                android:textColor="@color/grey_700"/>

            <TextView
                android:id="@+id/text_trans_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oct 24, 2023"
                android:textSize="11sp"
                android:textColor="@color/grey_700"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/text_trans_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ ₹0.00"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/success"/>

            <TextView
                android:id="@+id/text_trans_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30 Days"
                android:textSize="11sp"
                android:textColor="@color/grey_700"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
