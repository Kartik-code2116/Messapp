<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_user_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Scrollable Content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="96dp">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_mess_condition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/user_page_padding_h" android:layout_marginEnd="@dimen/user_page_padding_h"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                style="@style/Profound.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mess Status"
                            android:textSize="12sp"
                            android:textColor="@color/text_caption"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/text_mess_condition"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textSize="18sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold"
                            android:textColor="@color/text_heading"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/indicator_mess_condition"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_circle_surface"
                        android:backgroundTint="@color/neutral_400" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="@dimen/user_page_padding_h" android:paddingEnd="@dimen/user_page_padding_h"
                android:paddingTop="28dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Today's Meals"
                    android:textSize="20sp"
                    android:fontFamily="@font/poppins"
                    android:textStyle="bold"
                    android:textColor="@color/text_heading"/>

                <TextView
                    android:id="@+id/text_view_week"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View Week"
                    android:textColor="@color/brand_primary"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:paddingStart="4dp" android:paddingEnd="4dp"
                    android:paddingTop="4dp" android:paddingBottom="4dp"/>
            </LinearLayout>

            <!-- Meal Cards Container (Keeping IDs consistent) -->
            <LinearLayout
                android:id="@+id/meals_container_new"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/user_page_padding_h" android:paddingEnd="@dimen/user_page_padding_h"
                android:clipToPadding="false">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_plan_out_days"
                    style="@style/Profound.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Plan OUT Days"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_calendar"
                    app:strokeColor="@color/neutral_300"
                    android:textColor="@color/text_heading" />

                <!-- Auto-Select Daily Meal (Lunch/Dinner subscribers only) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_daily_auto_select"
                    style="@style/Profound.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_marginEnd="10dp"
                                android:src="@drawable/ic_schedule"
                                app:tint="@color/brand_primary" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Auto-Select Daily Meal"
                                android:textSize="16sp"
                                android:fontFamily="@font/poppins"
                                android:textStyle="bold"
                                android:textColor="@color/text_heading" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Enable to be automatically counted as IN every day without manually selecting. You can still mark OUT to skip."
                            android:textSize="12sp"
                            android:layout_marginBottom="16dp"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/text_body" />

                        <!-- Lunch auto-select row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_rounded_card_surface"
                                android:backgroundTint="@color/brand_primary_light"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_restaurant"
                                    app:tint="@color/brand_primary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Lunch"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/inter"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_heading" />
                                <TextView
                                    android:id="@+id/text_auto_lunch_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Auto-select off"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/inter"
                                    android:textColor="@color/text_caption" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/switch_auto_lunch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginBottom="12dp" />

                        <!-- Dinner auto-select row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_rounded_card_surface"
                                android:backgroundTint="@color/brand_secondary_light"
                                android:layout_marginEnd="12dp">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_restaurant"
                                    app:tint="@color/brand_secondary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Dinner"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/inter"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_heading" />
                                <TextView
                                    android:id="@+id/text_auto_dinner_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Auto-select off"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/inter"
                                    android:textColor="@color/text_caption" />
                            </LinearLayout>

                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/switch_auto_dinner"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_one_time_auto_select"
                    style="@style/Profound.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Auto-Select Daily Meal"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold"
                            android:textColor="@color/text_heading" />
                        
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Choose your preferred meal. We will automatically assume you are IN for it every day."
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter"
                            android:textColor="@color/text_body" />

                        <RadioGroup
                            android:id="@+id/radio_group_auto_select"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/radio_auto_none"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="None" />
                                
                            <RadioButton
                                android:id="@+id/radio_auto_lunch"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="Lunch" />

                            <RadioButton
                                android:id="@+id/radio_auto_dinner"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="Dinner" />
                        </RadioGroup>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_planned_out_days"
                    style="@style/Profound.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Planned OUT Days"
                            android:textSize="16sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold"
                            android:textColor="@color/text_heading" />

                        <LinearLayout
                            android:id="@+id/container_planned_out_days"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Breakfast Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_breakfast"
                    style="@style/Profound.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp">

                             <!-- Icon -->
                            <FrameLayout
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_rounded_card_surface"
                                android:backgroundTint="@color/brand_primary_light">
                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@drawable/ic_breakfast_dining"
                                    android:layout_gravity="center"
                                    app:tint="@color/brand_primary"/>
                                <ImageView
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:layout_gravity="top|end"
                                    android:layout_marginTop="-8dp"
                                    android:layout_marginEnd="-4dp"
                                    android:alpha="0.5"
                                    android:src="@drawable/ic_steam_subtle"/>
                            </FrameLayout>

                            <!-- Content -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:layout_gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_weight="1"
                                        android:layout_height="wrap_content"
                                        android:text="Breakfast"
                                        android:textSize="18sp"
                                        android:fontFamily="@font/poppins"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_heading"/>
                                    
                                    <TextView
                                        android:id="@+id/text_breakfast_badge"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="AVAILABLE"
                                        android:textSize="11sp"
                                        android:fontFamily="@font/inter"
                                        android:textStyle="bold"
                                        android:textColor="@color/brand_primary"
                                        android:background="@drawable/bg_rounded_card_surface"
                                        android:backgroundTint="@color/brand_primary_light"
                                        android:paddingStart="8dp" android:paddingEnd="8dp"
                                        android:paddingTop="4dp" android:paddingBottom="4dp"/>
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/text_breakfast_menu"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Loading breakfast items..."
                                    android:textSize="14sp"
                                    android:fontFamily="@font/inter"
                                    android:textColor="@color/text_body"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                        
                        <!-- Status Bar -->
                        <TextView
                            android:id="@+id/text_breakfast_status_bar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/neutral_100"
                            android:text="Status: Not Selected"
                            android:textColor="@color/text_sub"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:padding="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Lunch Card (Active) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_lunch"
                    style="@style/Profound.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        
                         <!-- Card Content -->
                         <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingStart="20dp" android:paddingEnd="20dp"
                            android:paddingTop="20dp"
                            android:paddingBottom="12dp">

                            <!-- Icon -->
                            <FrameLayout
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_rounded_card_surface"
                                android:backgroundTint="@color/brand_primary_light">
                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@drawable/ic_lunch_dining"
                                    android:layout_gravity="center"
                                    app:tint="@color/brand_primary"/>
                                <ImageView
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:layout_gravity="top|end"
                                    android:layout_marginTop="-8dp"
                                    android:layout_marginEnd="-4dp"
                                    android:alpha="0.55"
                                    android:src="@drawable/ic_steam_subtle"/>
                            </FrameLayout>

                            <!-- Content -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:layout_gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Lunch"
                                        android:textSize="18sp"
                                        android:fontFamily="@font/poppins"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_heading"/>

                                    <TextView
                                        android:id="@+id/text_lunch_preference"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="VEG"
                                        android:textSize="11sp"
                                        android:fontFamily="@font/inter"
                                        android:textStyle="bold"
                                        android:textColor="@color/semantic_success"
                                        android:background="@drawable/bg_rounded_card_surface"
                                        android:backgroundTint="@color/semantic_success_bg"
                                        android:paddingStart="8dp" android:paddingEnd="8dp"
                                        android:paddingTop="4dp" android:paddingBottom="4dp"
                                        android:visibility="gone"
                                        tools:visibility="visible"/>

                                    <TextView
                                        android:id="@+id/text_lunch_card_timer"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="--:--"
                                        android:textSize="11sp"
                                        android:fontFamily="@font/inter"
                                        android:textStyle="bold"
                                        android:textColor="@color/semantic_error"
                                        android:background="@drawable/bg_rounded_card_surface"
                                        android:backgroundTint="@color/semantic_error_bg"
                                        android:paddingStart="8dp" android:paddingEnd="8dp"
                                        android:paddingTop="4dp" android:paddingBottom="4dp"
                                        android:visibility="gone"
                                        tools:visibility="visible"/>
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/text_lunch_menu_new"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Grilled chicken breast, quinoa pilaf, fresh garden salad"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/inter"
                                    android:textColor="@color/text_sub"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="20dp" android:paddingEnd="20dp"
                            android:paddingBottom="20dp"
                            android:orientation="vertical">
                            
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_lunch_in_new"
                                    style="@style/Profound.Button"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="IN"
                                    android:textStyle="bold"
                                    app:icon="@drawable/ic_check_circle"
                                    android:layout_marginEnd="8dp"/>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_lunch_out_new"
                                    style="@style/Profound.Button.Outlined"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="OUT"
                                    android:textStyle="bold"
                                    app:strokeColor="@color/neutral_300"
                                    android:textColor="@color/text_sub"
                                    android:layout_marginStart="8dp"/>
                            </LinearLayout>

                             <!-- Status Text -->
                            <TextView
                                android:id="@+id/text_lunch_status"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:paddingTop="8dp"
                                android:text=""
                                android:textSize="12sp"
                                android:fontFamily="@font/inter"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Permanent Status Bar -->
                        <TextView
                            android:id="@+id/text_lunch_status_bar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/neutral_100"
                            android:text="Status: Not Marked"
                            android:textColor="@color/text_heading"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:padding="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Dinner Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_dinner"
                    style="@style/Profound.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                     <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <!-- Icon -->
                            <FrameLayout
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_rounded_card_surface"
                                android:backgroundTint="@color/brand_secondary_light">
                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:src="@drawable/ic_dinner_dining"
                                    android:layout_gravity="center"
                                    app:tint="@color/brand_secondary"/>
                                <ImageView
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:layout_gravity="top|end"
                                    android:layout_marginTop="-8dp"
                                    android:layout_marginEnd="-4dp"
                                    android:alpha="0.55"
                                    android:src="@drawable/ic_steam_subtle"/>
                            </FrameLayout>

                            <!-- Content -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp"
                                android:layout_gravity="center_vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Dinner"
                                        android:textSize="18sp"
                                        android:fontFamily="@font/poppins"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_heading"/>

                                    <TextView
                                        android:id="@+id/text_dinner_preference"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="VEG"
                                        android:textSize="11sp"
                                        android:fontFamily="@font/inter"
                                        android:textStyle="bold"
                                        android:textColor="@color/semantic_success"
                                        android:background="@drawable/bg_rounded_card_surface"
                                        android:backgroundTint="@color/semantic_success_bg"
                                        android:paddingStart="8dp" android:paddingEnd="8dp"
                                        android:paddingTop="4dp" android:paddingBottom="4dp"
                                        android:visibility="gone"
                                        tools:visibility="visible"/>

                                    <TextView
                                        android:id="@+id/text_dinner_card_timer"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="--:--"
                                        android:textSize="11sp"
                                        android:fontFamily="@font/inter"
                                        android:textStyle="bold"
                                        android:textColor="@color/semantic_error"
                                        android:background="@drawable/bg_rounded_card_surface"
                                        android:backgroundTint="@color/semantic_error_bg"
                                        android:paddingStart="8dp" android:paddingEnd="8dp"
                                        android:paddingTop="4dp" android:paddingBottom="4dp"
                                        android:visibility="gone"
                                        tools:visibility="visible"/>
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/text_dinner_menu_new"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Vegetable pasta alfredo, garlic bread, roasted broccoli"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/inter"
                                    android:textColor="@color/text_sub"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="20dp" android:paddingEnd="20dp"
                            android:paddingBottom="20dp"
                            android:orientation="vertical">
                            
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_dinner_in_new"
                                    style="@style/Profound.Button"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="IN"
                                    android:textStyle="bold"
                                    app:icon="@drawable/ic_check_circle"
                                    android:layout_marginEnd="8dp"/>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btn_dinner_out_new"
                                    style="@style/Profound.Button.Outlined"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="OUT"
                                    android:textStyle="bold"
                                    app:strokeColor="@color/neutral_300"
                                    android:textColor="@color/text_sub"
                                    android:layout_marginStart="8dp"/>
                            </LinearLayout>

                             <!-- Status Text -->
                            <TextView
                                android:id="@+id/text_dinner_status"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:paddingTop="8dp"
                                android:text=""
                                android:textSize="12sp"
                                android:fontFamily="@font/inter"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Permanent Status Bar -->
                        <TextView
                            android:id="@+id/text_dinner_status_bar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/neutral_100"
                            android:text="Status: Not Marked"
                            android:textColor="@color/text_heading"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:gravity="center"
                            android:padding="12dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
