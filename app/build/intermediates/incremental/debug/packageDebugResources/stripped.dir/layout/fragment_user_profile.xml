<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:elevation="10dp"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        tools:context=".ui.user.profile.UserProfileFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="88dp">

            <!-- Header -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_header"
                android:paddingBottom="56dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <RelativeLayout
                        android:layout_width="104dp"
                        android:layout_height="104dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="104dp"
                            android:layout_height="104dp"
                            app:cardCornerRadius="52dp"
                            app:cardElevation="6dp"
                            app:strokeColor="@color/cream_bright"
                            app:strokeWidth="3dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/profile_image"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@color/surface_elevated"
                                android:contentDescription="Profile Image"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_person_black_24dp"
                                app:shapeAppearanceOverlay="@style/CircleImageStyle" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.floatingactionbutton.FloatingActionButton
                            android:id="@+id/btn_edit_profile_image"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:contentDescription="Edit Profile Image"
                            app:backgroundTint="@color/surface_card"
                            app:fabCustomSize="36dp"
                            app:maxImageSize="18dp"
                            app:srcCompat="@drawable/ic_edit"
                            app:tint="@color/brand_primary" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/text_profile_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/text_on_brand"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="John Doe" />

                    <TextView
                        android:id="@+id/text_profile_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.92"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_on_brand"
                        android:textSize="14sp"
                        tools:text="john.doe@example.com" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_profile_badge"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.06"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:paddingTop="5dp" android:paddingBottom="5dp"
                        android:text="STUDENT"
                        android:textColor="@color/text_on_brand"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <!-- Contact Info Section -->
                <TextView
                    style="@style/ProfileSectionTitle"
                    android:text="CONTACT INFO" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/ProfileCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Name Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_profile_icon_circle">

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_person"
                                    app:tint="@color/brand_primary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter"
                                    android:text="Name"
                                    android:textColor="@color/text_caption"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/text_profile_name_card"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:textColor="@color/text_heading"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    tools:text="John Doe" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
                            android:background="@color/divider" />

                        <!-- Phone Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_profile_icon_circle">

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_call"
                                    app:tint="@color/brand_primary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter"
                                    android:text="Phone"
                                    android:textColor="@color/text_caption"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/text_profile_phone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:textColor="@color/text_heading"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    tools:text="+91 98765 43210" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
                            android:background="@color/divider" />

                        <!-- Email Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_profile_icon_circle">

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_email"
                                    app:tint="@color/brand_primary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter"
                                    android:text="Email"
                                    android:textColor="@color/text_caption"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/text_profile_email_card"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:textColor="@color/text_heading"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    tools:text="john.doe@example.com" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    style="@style/ProfileSectionTitle"
                    android:text="APPEARANCE" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/ProfileCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_profile_icon_circle">

                                <ImageView
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_restaurant"
                                    app:tint="@color/brand_primary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/inter"
                                    android:text="Mess"
                                    android:textColor="@color/text_caption"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/text_profile_mess_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/poppins"
                                    android:textColor="@color/text_heading"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    tools:text="Sunshine Mess" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
                            android:background="@color/divider" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:text="Meal plans"
                            android:textColor="@color/text_caption"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/text_lunch_expiry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="Lunch · Active (12d left)"
                            tools:textColor="@color/state_success" />

                        <TextView
                            android:id="@+id/text_dinner_expiry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/inter"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="Dinner · Active (12d left)"
                            tools:textColor="@color/state_success" />

                        <TextView
                            android:id="@+id/text_one_time_expiry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/inter"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            tools:text="One Time · Active (12d left)"
                            tools:textColor="@color/state_success" />

                        <TextView
                            android:id="@+id/text_subscription_expiry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/text_profile_mess_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_renew_subscription"
                            style="@style/Profound.Button.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Renew subscription"
                            app:strokeColor="@color/brand_primary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    style="@style/ProfileSectionTitle"
                    android:text="APPEARANCE" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/ProfileCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:paddingTop="14dp" android:paddingBottom="14dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_profile_icon_circle">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dark_mode"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter"
                            android:text="Dark mode"
                            android:textColor="@color/text_heading"
                            android:textSize="16sp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_dark_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    style="@style/ProfileSectionTitle"
                    android:text="ACCOUNT" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/ProfileCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="4dp" android:paddingBottom="4dp">

                        <LinearLayout
                            android:id="@+id/btn_my_reviews"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp" android:paddingEnd="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_profile_icon_circle">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_star_rate"
                                    app:tint="@color/brand_primary" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/inter"
                                android:text="Mess reviews"
                                android:textColor="@color/text_heading"
                                android:textSize="15sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/text_placeholder" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:id="@+id/btn_change_password"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp" android:paddingEnd="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_profile_icon_circle">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_lock"
                                    app:tint="@color/brand_primary" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/inter"
                                android:text="Change password"
                                android:textColor="@color/text_heading"
                                android:textSize="15sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/text_placeholder" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:id="@+id/btn_help_support"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp" android:paddingEnd="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_profile_icon_circle">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_info"
                                    app:tint="@color/brand_primary" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/inter"
                                android:text="Help &amp; support"
                                android:textColor="@color/text_heading"
                                android:textSize="15sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/text_placeholder" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                            android:background="@color/divider" />

                        <LinearLayout
                            android:id="@+id/btn_logout"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp" android:paddingEnd="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_profile_icon_circle">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_lock"
                                    app:tint="@color/state_error" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/inter"
                                android:text="Log out"
                                android:textColor="@color/state_error"
                                android:textSize="15sp" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/text_placeholder" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
