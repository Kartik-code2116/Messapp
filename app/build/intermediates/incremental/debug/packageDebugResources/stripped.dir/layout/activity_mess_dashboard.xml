<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <!-- We removed the standard toolbar to let fragments handle their own headers -->

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment_activity_mess_dashboard"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/nav_view_container"
        app:defaultNavHost="true"
        app:navGraph="@navigation/mess_navigation" />

    <LinearLayout
        android:id="@+id/nav_view_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/neutral_200"/>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/nav_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_card"
            android:elevation="0dp"
            app:itemIconTint="@color/selector_nav_admin"
            app:itemTextColor="@color/selector_nav_admin"
            app:itemRippleColor="@color/brand_primary_light"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu_mess"
            app:itemActiveIndicatorStyle="@style/Widget.Material3.BottomNavigationView.ActiveIndicator" />
    </LinearLayout>

</RelativeLayout>