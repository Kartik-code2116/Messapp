<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_page">

        <include
            android:id="@+id/admin_top_bar"
            layout="@layout/include_admin_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true" />

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment_activity_mess_dashboard"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/nav_view_container"
            android:layout_below="@id/admin_top_bar"
            app:defaultNavHost="true"
            app:navGraph="@navigation/mess_navigation" />

        <LinearLayout
            android:id="@+id/nav_view_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/neutral_200"/>

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/nav_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface_card"
                android:elevation="0dp"
                app:itemIconTint="@color/selector_nav_admin"
                app:itemTextColor="@color/selector_nav_admin"
                app:itemRippleColor="@color/brand_primary_light"
                app:labelVisibilityMode="labeled"
                app:menu="@menu/bottom_nav_menu_mess"
                app:itemActiveIndicatorStyle="@style/Widget.Material3.BottomNavigationView.ActiveIndicator" />
        </LinearLayout>

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/profile_drawer"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/surface_card"
        android:fitsSystemWindows="false"
        app:headerLayout="@layout/header_admin_profile_drawer"
        app:itemIconPadding="16dp"
        app:itemIconSize="22dp"
        app:itemHorizontalPadding="20dp"
        app:itemVerticalPadding="12dp"
        app:itemIconTint="@color/text_secondary"
        app:itemTextColor="@color/text_primary"
        app:itemShapeFillColor="@color/brand_primary_light"
        app:itemRippleColor="@color/brand_primary_light"
        app:subheaderTextAppearance="@style/TextAppearance.Material3.LabelMedium"
        app:menu="@menu/menu_admin_profile_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>