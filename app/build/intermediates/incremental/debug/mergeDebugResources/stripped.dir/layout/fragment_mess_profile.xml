<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page"
    android:clipToPadding="false"
    android:fillViewport="true"
    tools:context=".ui.mess.profile.MessProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header"
            android:paddingBottom="56dp">

            <ImageView
                android:id="@+id/btn_logout_top"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Logout"
                android:padding="8dp"
                android:src="@drawable/ic_lock"
                app:tint="@color/text_on_brand" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="8dp">

                <RelativeLayout
                    android:layout_width="104dp"
                    android:layout_height="104dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="104dp"
                        android:layout_height="104dp"
                        app:cardCornerRadius="52dp"
                        app:cardElevation="6dp"
                        app:strokeColor="@color/cream_bright"
                        app:strokeWidth="3dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/mess_profile_image"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/surface_elevated"
                            android:contentDescription="Mess Profile Image"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_account_circle"
                            app:shapeAppearanceOverlay="@style/CircleImageStyle" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btn_edit_profile_image"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:contentDescription="Edit Profile Image"
                        app:backgroundTint="@color/surface_card"
                        app:fabCustomSize="36dp"
                        app:maxImageSize="18dp"
                        app:srcCompat="@drawable/ic_edit"
                        app:tint="@color/brand_primary" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/text_mess_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/poppins"
                    android:textColor="@color/text_on_brand"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="Sunshine Mess" />

                <TextView
                    android:id="@+id/text_owner_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:alpha="0.92"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/text_on_brand"
                    android:textSize="14sp"
                    tools:text="owner@example.com" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_profile_badge"
                    android:fontFamily="@font/inter"
                    android:letterSpacing="0.06"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:paddingTop="5dp" android:paddingBottom="5dp"
                    android:text="MESS OWNER"
                    android:textColor="@color/text_on_brand"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-40dp"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp">

            <com.google.android.material.card.MaterialCardView
                style="@style/ProfileCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/label_mess_details"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/poppins"
                            android:text="Mess Details"
                            android:textColor="@color/text_heading"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/container_mess_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_profile_icon_circle"
                            android:foreground="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="10dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="10dp"
                            android:paddingBottom="6dp">

                            <TextView
                                android:id="@+id/text_mess_profile_id"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:textColor="@color/text_body"
                                android:textSize="11sp"
                                tools:text="#MS-9921" />

                            <ImageView
                                android:id="@+id/btn_copy_mess_id"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginStart="6dp"
                                android:contentDescription="Copy ID"
                                android:src="@drawable/ic_edit"
                                app:tint="@color/brand_primary" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
                        android:background="@color/divider" />

                    <!-- Location Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_profile_icon_circle">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_location_on"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:text="Address"
                                android:textColor="@color/text_caption"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/text_mess_profile_location"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/poppins"
                                android:textColor="@color/text_heading"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="123 Campus Road, Block A" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Contact Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_profile_icon_circle">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_call"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:text="Contact Number"
                                android:textColor="@color/text_caption"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/text_mess_profile_contact"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/poppins"
                                android:textColor="@color/text_heading"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="+91 98765 43210" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Description Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_profile_icon_circle">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_info"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:text="Description"
                                android:textColor="@color/text_caption"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/text_mess_profile_description"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/poppins"
                                android:textColor="@color/text_heading"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="A friendly mess serving homely meals every day." />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/ProfileCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Analytics"
                        android:textColor="@color/text_heading"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp" android:layout_marginBottom="16dp"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/label_active_students"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter"
                            android:letterSpacing="0.05"
                            android:text="Active students"
                            android:textColor="@color/text_caption"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_profile_icon_circle"
                            android:fontFamily="@font/inter"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="4dp" android:paddingBottom="4dp"
                            android:text="LIVE"
                            android:textColor="@color/state_success"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_active_students_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/poppins"
                        android:textColor="@color/text_heading"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        tools:text="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:contentDescription="Trend"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/state_success" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="@font/inter"
                            android:text="Enrolled this month"
                            android:textColor="@color/state_success"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_view_students"
                        style="@style/Profound.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="View student list"
                        app:strokeColor="@color/brand_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/ProfileCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Reviews"
                        android:textColor="@color/text_heading"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter"
                        android:text="See feedback written by students for your mess."
                        android:textColor="@color/text_caption"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_see_reviews"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="See User Reviews" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_write_review"
                            style="@style/Profound.Button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="Write Review"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/ProfileCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="4dp" android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Management"
                        android:textColor="@color/text_heading"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:paddingTop="12dp" android:paddingBottom="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:layout_marginTop="8dp" android:layout_marginBottom="8dp"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:id="@+id/btn_nav_edit_profile"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp" android:paddingEnd="16dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_profile_icon_circle">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_edit"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter"
                            android:text="Edit mess profile"
                            android:textColor="@color/text_heading"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Navigate"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_placeholder" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:id="@+id/btn_nav_offers"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp" android:paddingEnd="16dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_profile_icon_circle">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_local_offer"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter"
                            android:text="Campaigns &amp; offers"
                            android:textColor="@color/text_heading"
                            android:textSize="15sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_profile_icon_circle"
                            android:fontFamily="@font/inter"
                            android:paddingStart="8dp" android:paddingEnd="8dp"
                            android:paddingTop="3dp" android:paddingBottom="3dp"
                            android:text="3"
                            android:textColor="@color/brand_primary"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Navigate"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_placeholder" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:id="@+id/btn_nav_revenue"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp" android:paddingEnd="16dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_profile_icon_circle">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bar_chart"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter"
                            android:text="Revenue reports"
                            android:textColor="@color/text_heading"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Navigate"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_placeholder" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:id="@+id/btn_nav_weekly_menu"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp" android:paddingEnd="16dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_profile_icon_circle">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter"
                            android:text="Weekly menu"
                            android:textColor="@color/text_heading"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="Navigate"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_placeholder" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/ProfileCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="4dp" android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Appearance"
                        android:textColor="@color/text_heading"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:paddingTop="12dp" android:paddingBottom="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:layout_marginTop="8dp" android:layout_marginBottom="8dp"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:paddingTop="10dp" android:paddingBottom="10dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_profile_icon_circle">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_dark_mode"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter"
                            android:text="Dark mode"
                            android:textColor="@color/text_heading"
                            android:textSize="16sp" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switch_dark_mode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/ProfileCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="4dp" android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="Support"
                        android:textColor="@color/text_heading"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:paddingTop="12dp" android:paddingBottom="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                        android:layout_marginTop="8dp" android:layout_marginBottom="8dp"
                        android:background="@color/divider" />

                    <LinearLayout
                        android:id="@+id/btn_help_support"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp" android:paddingEnd="16dp">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_profile_icon_circle">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_info"
                                app:tint="@color/brand_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter"
                            android:text="Help &amp; support"
                            android:textColor="@color/text_heading"
                            android:textSize="15sp" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_placeholder" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_mess_logout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Log out"
                android:textColor="@color/state_error"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_lock"
                app:iconGravity="textStart"
                app:iconTint="@color/state_error"
                app:strokeColor="@color/state_error" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:text="MessApp · Owner"
                android:textColor="@color/text_caption"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
