<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:elevation="10dp"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        tools:context=".ui.mess.dashboard.MessDashboardFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Header Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="32dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:id="@+id/header_mess_dashboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/text_dashboard_timer">

                    <TextView
                        android:id="@+id/text_mess_dashboard_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mess Name Placeholder"
                        android:textSize="22sp"
                        android:fontFamily="@font/poppins"
                        android:textStyle="bold"
                        android:textColor="@color/text_heading"/>

                    <TextView
                        android:id="@+id/text_mess_dashboard_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date Placeholder"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_sub"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/text_dashboard_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_rounded_card_surface"
                    android:backgroundTint="@color/semantic_error_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:text="Deadline: --:--"
                    android:textColor="@color/semantic_error"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </RelativeLayout>

            <!-- Mess Condition Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                style="@style/Profound.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_rounded_card_surface"
                            android:backgroundTint="@color/brand_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="MESS CONDITION"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter"
                            android:textStyle="bold"
                            android:textColor="@color/text_caption"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Update availability status for students"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_sub"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_condition_full"
                            style="@style/Profound.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="FULL"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/semantic_error"
                            app:strokeColor="@color/semantic_error" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_condition_half"
                            style="@style/Profound.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="4dp"
                            android:text="HALF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/semantic_warning"
                            app:strokeColor="@color/semantic_warning" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_condition_empty"
                            style="@style/Profound.Button.Outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="EMPTY"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/semantic_success"
                            app:strokeColor="@color/semantic_success" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_current_condition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Current: Not Set"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/text_sub"
                        android:textStyle="italic" 
                        android:gravity="center"
                        android:layout_gravity="center_horizontal"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_reset_all_attendance"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="RESET ALL ATTENDANCE"
                        android:textColor="@color/brand_primary"
                        android:textSize="12sp"
                        android:fontFamily="@font/inter"
                        android:textStyle="bold"
                        app:icon="@drawable/ic_restore"
                        app:iconTint="@color/brand_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stats Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                style="@style/Profound.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_rounded_card_surface"
                        android:backgroundTint="@color/brand_primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL STUDENTS"
                            android:textColor="@color/text_caption"
                            android:textSize="11sp"
                            android:fontFamily="@font/inter"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/text_total_students"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_heading"
                            android:textSize="32sp"
                            android:fontFamily="@font/poppins"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_surface"
                        android:backgroundTint="@color/brand_primary_light">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_group"
                            app:tint="@color/brand_primary" />
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Lunch Count Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                style="@style/Profound.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_rounded_card_surface"
                            android:backgroundTint="@color/brand_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="LUNCH STATUS"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter"
                            android:textStyle="bold"
                            android:textColor="@color/text_caption"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="IN"
                                android:textSize="12sp"
                                android:textColor="@color/text_sub"
                                android:fontFamily="@font/inter"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/text_lunch_in_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="32sp"
                                android:fontFamily="@font/poppins"
                                android:textStyle="bold"
                                android:textColor="@color/semantic_success"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="OUT"
                                android:textSize="12sp"
                                android:textColor="@color/text_sub"
                                android:fontFamily="@font/inter"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/text_lunch_out_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="32sp"
                                android:fontFamily="@font/poppins"
                                android:textStyle="bold"
                                android:textColor="@color/semantic_error"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Dinner Count Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                style="@style/Profound.Card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_rounded_card_surface"
                            android:backgroundTint="@color/brand_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="DINNER STATUS"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter"
                            android:textStyle="bold"
                            android:textColor="@color/text_caption"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="IN"
                                android:textSize="12sp"
                                android:textColor="@color/text_sub"
                                android:fontFamily="@font/inter"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/text_dinner_in_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="32sp"
                                android:fontFamily="@font/poppins"
                                android:textStyle="bold"
                                android:textColor="@color/semantic_success"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="OUT"
                                android:textSize="12sp"
                                android:textColor="@color/text_sub"
                                android:fontFamily="@font/inter"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/text_dinner_out_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="32sp"
                                android:fontFamily="@font/poppins"
                                android:textStyle="bold"
                                android:textColor="@color/semantic_error"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pending Requests Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:text="SUBSCRIPTION REQUESTS"
                android:textSize="12sp"
                android:fontFamily="@font/inter"
                android:textStyle="bold"
                android:textColor="@color/text_caption"
                android:letterSpacing="0.05"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_pending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:paddingBottom="20dp"
                tools:listitem="@layout/item_student_request"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>